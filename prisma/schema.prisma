generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  email        String
  phone        String
  address      String
  total        Float
  status       String      @default("New")
  createdAt    DateTime    @default(now())
  items        OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Float
  image     String
  size      String
  color     String
  quantity  Int
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}